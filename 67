<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Capital Quiz</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:#0a0f1e;color:#f0efe8;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1.5rem;}
.card{width:100%;max-width:400px;background:#111827;border-radius:20px;overflow:hidden;border:1px solid #1e2d4a;}
.top{background:linear-gradient(135deg,#1a2744,#0d1f3c);padding:1.5rem;text-align:center;border-bottom:1px solid #1e2d4a;}
.globe{font-size:48px;margin-bottom:0.5rem;}
h1{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#e8f4ff;}
.streak{margin-top:0.5rem;font-size:13px;color:#6b8cba;}
.streak span{color:#f0c060;font-weight:500;}
.body{padding:1.5rem;}
.q-label{font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#4a6a9a;margin-bottom:0.5rem;}
.question{font-family:'Syne',sans-serif;font-size:20px;font-weight:700;color:#e8f4ff;margin-bottom:1.5rem;line-height:1.3;min-height:56px;}
.options{display:flex;flex-direction:column;gap:10px;margin-bottom:1rem;}
.opt{background:#1a2540;border:1.5px solid #1e2d4a;border-radius:12px;padding:0.9rem 1.1rem;font-size:15px;color:#c8daf0;cursor:pointer;transition:all 0.15s;text-align:left;font-family:'DM Sans',sans-serif;}
.opt:hover:not(:disabled){background:#1e3050;border-color:#2a4070;color:#e8f4ff;}
.opt.correct{background:#0d3020;border-color:#1a7a4a;color:#4ee89a;}
.opt.wrong{background:#2d0d0d;border-color:#7a1a1a;color:#e84a4a;}
.opt:disabled{cursor:default;}
.feedback{text-align:center;font-size:14px;min-height:24px;margin-bottom:1rem;font-weight:500;}
.feedback.good{color:#4ee89a;}
.feedback.bad{color:#e84a4a;}
.next-btn{width:100%;background:#2a5cff;border:none;border-radius:12px;padding:0.9rem;font-size:15px;font-weight:500;color:#fff;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background 0.15s;display:none;}
.next-btn:hover{background:#1a4cef;}
</style>
</head>
<body>
<div class="card">
  <div class="top">
    <div class="globe">🌍</div>
    <h1>Capital Quiz</h1>
    <div class="streak">Streak: <span id="streak">0</span> &nbsp;·&nbsp; Score: <span id="score">0</span></div>
  </div>
  <div class="body">
    <div class="q-label">What is the capital of...</div>
    <div class="question" id="question">Loading...</div>
    <div class="options" id="options"></div>
    <div class="feedback" id="feedback"></div>
    <button class="next-btn" id="next-btn" onclick="nextQuestion()">Next question →</button>
  </div>
</div>
<script>
const pool = [
  {country:"Norway",capital:"Oslo",others:["Bergen","Stockholm","Helsinki"]},
  {country:"Sweden",capital:"Stockholm",others:["Gothenburg","Oslo","Copenhagen"]},
  {country:"Denmark",capital:"Copenhagen",others:["Aarhus","Stockholm","Hamburg"]},
  {country:"Germany",capital:"Berlin",others:["Munich","Hamburg","Frankfurt"]},
  {country:"Iceland",capital:"Reykjavik",others:["Akureyri","Oslo","Dublin"]},
  {country:"France",capital:"Paris",others:["Lyon","Brussels","Madrid"]},
  {country:"Spain",capital:"Madrid",others:["Barcelona","Lisbon","Paris"]},
  {country:"Italy",capital:"Rome",others:["Milan","Naples","Florence"]},
  {country:"Japan",capital:"Tokyo",others:["Osaka","Kyoto","Hiroshima"]},
  {country:"Brazil",capital:"Brasilia",others:["Sao Paulo","Rio de Janeiro","Salvador"]},
  {country:"Australia",capital:"Canberra",others:["Sydney","Melbourne","Brisbane"]},
  {country:"Canada",capital:"Ottawa",others:["Toronto","Vancouver","Montreal"]},
  {country:"India",capital:"New Delhi",others:["Mumbai","Kolkata","Chennai"]},
  {country:"China",capital:"Beijing",others:["Shanghai","Guangzhou","Shenzhen"]},
  {country:"Russia",capital:"Moscow",others:["Saint Petersburg","Novosibirsk","Kazan"]},
  {country:"Egypt",capital:"Cairo",others:["Alexandria","Luxor","Giza"]},
  {country:"South Africa",capital:"Pretoria",others:["Cape Town","Johannesburg","Durban"]},
  {country:"Argentina",capital:"Buenos Aires",others:["Cordoba","Rosario","Mendoza"]},
  {country:"Mexico",capital:"Mexico City",others:["Guadalajara","Monterrey","Puebla"]},
  {country:"Portugal",capital:"Lisbon",others:["Porto","Braga","Coimbra"]},
  {country:"Greece",capital:"Athens",others:["Thessaloniki","Patras","Heraklion"]},
  {country:"Netherlands",capital:"Amsterdam",others:["Rotterdam","The Hague","Utrecht"]},
  {country:"Poland",capital:"Warsaw",others:["Krakow","Lodz","Gdansk"]},
  {country:"Turkey",capital:"Ankara",others:["Istanbul","Izmir","Bursa"]},
  {country:"Saudi Arabia",capital:"Riyadh",others:["Jeddah","Mecca","Medina"]},
  {country:"Finland",capital:"Helsinki",others:["Tampere","Turku","Oulu"]},
  {country:"Switzerland",capital:"Bern",others:["Zurich","Geneva","Basel"]},
  {country:"Austria",capital:"Vienna",others:["Graz","Linz","Salzburg"]},
  {country:"Belgium",capital:"Brussels",others:["Antwerp","Ghent","Bruges"]},
  {country:"Ireland",capital:"Dublin",others:["Cork","Galway","Limerick"]},
  {country:"New Zealand",capital:"Wellington",others:["Auckland","Christchurch","Hamilton"]},
  {country:"South Korea",capital:"Seoul",others:["Busan","Incheon","Daegu"]},
  {country:"Thailand",capital:"Bangkok",others:["Chiang Mai","Phuket","Pattaya"]},
  {country:"Kenya",capital:"Nairobi",others:["Mombasa","Kisumu","Nakuru"]},
  {country:"Nigeria",capital:"Abuja",others:["Lagos","Kano","Ibadan"]},
];
 
let streak = 0, score = 0, used = [], current = null;
 
function shuffle(a) { return a.sort(() => Math.random() - 0.5); }
 
function nextQuestion() {
  if (used.length === pool.length) used = [];
  const remaining = pool.filter((_, i) => !used.includes(i));
  const idx = pool.indexOf(remaining[Math.floor(Math.random() * remaining.length)]);
  used.push(idx);
  current = pool[idx];
 
  document.getElementById('question').textContent = current.country;
  document.getElementById('feedback').textContent = '';
  document.getElementById('feedback').className = 'feedback';
  document.getElementById('next-btn').style.display = 'none';
 
  const opts = shuffle([current.capital, ...current.others.slice(0, 3)]);
  const container = document.getElementById('options');
  container.innerHTML = '';
  opts.forEach(o => {
    const btn = document.createElement('button');
    btn.className = 'opt';
    btn.textContent = o;
    btn.onclick = () => answer(o, btn);
    container.appendChild(btn);
  });
}
 
function answer(choice, btn) {
  document.querySelectorAll('.opt').forEach(b => b.disabled = true);
  const fb = document.getElementById('feedback');
  if (choice === current.capital) {
    btn.classList.add('correct');
    streak++; score += 10;
    fb.textContent = '✓ Correct!';
    fb.className = 'feedback good';
  } else {
    btn.classList.add('wrong');
    document.querySelectorAll('.opt').forEach(b => {
      if (b.textContent === current.capital) b.classList.add('correct');
    });
    streak = 0;
    fb.textContent = '✗ The answer was ' + current.capital;
    fb.className = 'feedback bad';
  }
  document.getElementById('streak').textContent = streak;
  document.getElementById('score').textContent = score;
  document.getElementById('next-btn').style.display = 'block';
}
 
nextQuestion();
</script>
</body>
</html>
